package router

import (
	{{json_import}}
	"errors"
	"os"
	"path/filepath"
	"strings"

	"github.com/gofiber/fiber/v2"
	"github.com/gofiber/fiber/v2/middleware/compress"
	"github.com/gofiber/fiber/v2/middleware/cors"
	"github.com/gofiber/fiber/v2/middleware/etag"
	"github.com/gofiber/fiber/v2/middleware/recover"
	"github.com/gofiber/fiber/v2/middleware/requestid"

	"{{module_path}}/config"
	usercontroller "{{module_path}}/internal/app/user/controller"
	applogging "{{module_path}}/internal/infra/logging"
	httpmiddleware "{{module_path}}/internal/transport/http/middleware"
	"{{module_path}}/internal/transport/http/webui"
	"{{module_path}}/pkg/common"
)

type Dependencies struct {
	Config   config.Config
	Logger   *applogging.Logger
	Services []string
}

type AppModules struct {
	UserAPI *usercontroller.API
}

func NewApp(deps Dependencies, modules AppModules) *fiber.App {
	logger := deps.Logger
	if logger == nil {
		logger = applogging.Default()
	}

	app := fiber.New(fiber.Config{
		DisableStartupMessage: true,
		JSONEncoder:          {{json_encoder}},
		JSONDecoder:          {{json_decoder}},
		ErrorHandler: func(c *fiber.Ctx, err error) error {
			logger.Error("request failed", applogging.String("path", c.Path()), applogging.String("error", err.Error()))
			status := fiber.StatusInternalServerError
			message := "internal server error"
			var fiberErr *fiber.Error
			if errors.As(err, &fiberErr) {
				status = fiberErr.Code
				message = fiberErr.Message
			} else {
				var appErr common.APIError
				if errors.As(err, &appErr) {
					status = appErr.HTTPStatus()
					message = appErr.Message()
				}
			}
			return common.Error(c, status, message)
		},
	})

	app.Use(requestid.New())
	app.Use(httpmiddleware.AccessLog(logger))
	app.Use(recover.New())
	app.Use(httpmiddleware.SecurityHeaders())
	app.Use(etag.New())
	if deps.Config.Middleware.Gzip.Enabled {
		app.Use(compress.New())
	}
	app.Use(cors.New(cors.Config{
		AllowOrigins: strings.Join(deps.Config.Middleware.CORS.AllowOrigins, ","),
	}))

	registerHealthRoutes(app, deps)
	api(wrapTimeoutRouter(app.Group("/api"), deps.Config.Middleware.Timeout), modules)
	registerSwaggerRoutes(app, deps.Config)
	registerEmbeddedUIRoutes(app, deps.Config)

	return app
}

func registerHealthRoutes(app *fiber.App, deps Dependencies) {
	payload := fiber.Map{
		"app_id":      deps.Config.Server.AppID,
		"app_name":    deps.Config.Server.AppName,
		"app_version": deps.Config.Server.AppVersion,
		"services":    deps.Services,
	}

	handler := func(c *fiber.Ctx) error {
		return common.Success(c, payload)
	}

	app.Get("/healthz", handler)
	app.Get("/livez", handler)
	app.Get("/readyz", handler)
	app.Get("/startupz", handler)
}

func registerSwaggerRoutes(app *fiber.App, cfg config.Config) {
	if !cfg.Swagger.Enabled {
		return
	}

	prefix := strings.TrimRight(cfg.Swagger.RoutePrefix, "/")
	if prefix == "" {
		prefix = "/docs"
	}
	openAPIPath := filepath.Join("docs", "openapi.yaml")
	if _, err := os.Stat(openAPIPath); err != nil {
		return
	}

	app.Get(prefix, func(c *fiber.Ctx) error {
		return c.Type("html").SendString(`<html><body><h1>API Docs</h1><p>OpenAPI: <a href="` + prefix + `/openapi.yaml">openapi.yaml</a></p></body></html>`)
	})
	app.Get(prefix+"/openapi.yaml", func(c *fiber.Ctx) error {
		return c.SendFile(openAPIPath)
	})
}

func registerEmbeddedUIRoutes(app *fiber.App, cfg config.Config) {
	if !cfg.EmbeddedUI.Enabled {
		return
	}

	prefix := strings.TrimRight(cfg.EmbeddedUI.RoutePrefix, "/")
	if prefix == "" {
		prefix = "/ui"
	}

	handler := func(c *fiber.Ctx) error {
		return c.Type("html").SendString(webui.IndexHTML())
	}

	app.Get(prefix, handler)
	app.Get(prefix+"/", handler)
	app.Get(prefix+"/*", handler)
}
